    {
      "name": "Posts API",
      "item": [
        {
          "name": "GET Posts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status is 200\", () =>\r",
                  "  pm.expect(pm.response.code).to.equal(200));\r",
                  "\r",
                  "pm.test(\"Returns an array\", () =>\r",
                  "  pm.expect(json).to.be.an(\"array\"));\r",
                  "\r",
                  "pm.test(\"Array is not empty\", () =>\r",
                  "  pm.expect(json.length).to.be.above(0));\r",
                  "\r",
                  "pm.test(\"Each post has required fields\", () => {\r",
                  "  pm.expect(json[0]).to.have.property(\"id\");\r",
                  "  pm.expect(json[0]).to.have.property(\"title\");\r",
                  "  pm.expect(json[0]).to.have.property(\"userId\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response under 1000ms\", () =>\r",
                  "  pm.expect(pm.response.responseTime).to.be.below(1000)); "
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"title\":\"Test\",\"body\":\"Hello\",\"userId\":1}"
            },
            "url": {
              "raw": "{{baseUrl}}/posts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "posts"
              ]
            }
          },
          "response": []
        },
